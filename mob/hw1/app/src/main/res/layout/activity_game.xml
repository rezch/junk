<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".GameActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        tools:ignore="MissingConstraints">

        <Space
            android:layout_width="match_parent"
            android:layout_height="50dp" />

        <TextView
            android:id="@+id/player_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Игрок: "
            android:textSize="18sp"
            android:layout_marginBottom="30dp" />

        <TextView
            android:id="@+id/result_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Сделайте ваш выбор!"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="30dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="20dp">

            <Button
                android:id="@+id/btn_rock"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Камень"
                android:layout_margin="5dp"
                android:padding="12dp" />

            <Button
                android:id="@+id/btn_paper"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Бумага"
                android:layout_margin="5dp"
                android:padding="12dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="20dp">

            <Button
                android:id="@+id/btn_scissors"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Ножницы"
                android:layout_margin="5dp"
                android:padding="12dp" />

            <Button
                android:id="@+id/btn_lizard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Ящерица"
                android:layout_margin="5dp"
                android:padding="12dp" />

        </LinearLayout>

        <Button
            android:id="@+id/btn_spock"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Спок"
            android:layout_margin="5dp"
            android:padding="12dp"
            android:layout_marginBottom="30dp" />

        <TextView
            android:id="@+id/player_choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ваш выбор: "
            android:textSize="16sp"
            android:layout_marginBottom="10dp" />

        <TextView
            android:id="@+id/computer_choice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Выбор компьютера: "
            android:textSize="16sp"
            android:layout_marginBottom="30dp" />

        <Button
            android:id="@+id/btn_new_round"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:padding="16dp"
            android:text="Новый раунд" />

        <Button
            android:id="@+id/btn_back"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:text="Назад" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>